{
    // If type is lldb-dab then needs "lldb-dap.executable-path": "/usr/bin/lldb-dap-18" set in the devcontainer to work
    "configurations": [
        {
            "type": "lldb-dap",
            "request": "launch",
            "name": "C: clang compile and debug current file",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${fileDirname}",
            "stopOnEntry": false,
            "preLaunchTask": "C: clang compile current file"
        },
        {
            "type": "lldb-dap",
            "request": "launch",
            "name": "C++: clang++ compile and debug current file",
            "program": "${fileDirname}/${fileBasenameNoExtension}",
            "args": [],
            "cwd": "${fileDirname}",
            "stopOnEntry": false,
            "preLaunchTask": "C++: clang++ compile current file"
        }
    ]
}
