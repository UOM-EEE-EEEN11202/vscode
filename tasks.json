    "version": "2.0.0",
    "tasks": [
        {
            "label": "C: clang compile current file",
            "type": "shell",
            "command": "echo",
            "args": [
                "-e",
                "\nTask complete. Press any key to close this view.\n"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "revealProblems": "onProblem",
                "focus": true,
                "echo": false,
                "showReuseMessage": false,
                "panel": "shared",
                "clear": false,
                "close": false
            },
            "group": {
                "kind": "build",
            },
            "dependsOn": "C: Compile",
            "dependsOrder": "sequence"
        },
